      "targets": [
        {
          "expr": "kcp_workspaces_total",
          "legendFormat": "{{ phase }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right" },
        "pieType": "donut",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "title": "APIBindings by Phase",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "kcp_apibindings_total",
          "legendFormat": "{{ phase }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right" },
        "pieType": "donut",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "title": "Workspaces Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "kcp_workspaces_total",
          "legendFormat": "{{ phase }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 20, "stacking": { "mode": "normal" } },
          "unit": "short"
        }
      }
    },
    {
      "title": "Logical Clusters Total",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "kcp_logical_clusters_total",
          "legendFormat": "Logical Clusters"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 10 },
          "unit": "short"
        }
      }
    },
    {
      "title": "Resource Summary",
      "type": "table",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "kcp_workspaces_total",
          "legendFormat": "Workspaces ({{ phase }})",
          "format": "table",
          "instant": true
        },
        {
          "expr": "kcp_apiexports_total",
          "legendFormat": "APIExports",
          "format": "table",
          "instant": true
        },
        {
          "expr": "kcp_apibindings_total",
          "legendFormat": "APIBindings ({{ phase }})",
          "format": "table",
          "instant": true
        },
        {
          "expr": "kcp_apiresourceschemas_total",
          "legendFormat": "APIResourceSchemas",
          "format": "table",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 100,
      "title": "API Sharing Topology",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 28 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 101,
      "title": "APIBinding Topology",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "kcp_apibinding_info",
          "legendFormat": "",
          "format": "table",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "noValue": "No bindings discovered yet" }
      },
      "transformations": [
        {
          "id": "labelsToFields",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Value": true,
              "__name__": true,
              "instance": true,
              "job": true
            },
            "renameByName": {
              "provider_workspace": "Provider",
              "export_name": "Export",
              "consumer_workspace": "Consumer",
              "phase": "Phase"
            }
          }
        }
      ]
    },
    {
      "id": 102,
      "title": "Total Bindings",
      "type": "stat",
      "gridPos": { "h": 8, "w": 4, "x": 12, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "count(kcp_apibinding_info) or vector(0)",
          "legendFormat": "Total"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      }
    },
    {
      "id": 103,
      "title": "Bound Ratio",
      "type": "stat",
      "gridPos": { "h": 8, "w": 4, "x": 16, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "(count(kcp_apibinding_info{phase=\"Bound\"}) or vector(0)) / clamp_min(count(kcp_apibinding_info), 1) * 100",
          "legendFormat": "Bound %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "green", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "id": 104,
      "title": "Unique Exports Consumed",
      "type": "stat",
      "gridPos": { "h": 8, "w": 4, "x": 20, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "count(count by (export_name, provider_workspace) (kcp_apibinding_info)) or vector(0)",
          "legendFormat": "Exports"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      }
    },
    {
      "id": 105,
      "title": "Workspace Lifecycle",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 37 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 106,
      "title": "Max Phase Duration (Non-Ready)",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 38 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "max by (phase) (kcp_workspace_phase_duration_seconds{phase!=\"Ready\"})",
          "legendFormat": "{{phase}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 300 },
              { "color": "red", "value": 900 }
            ]
          },
          "min": 0,
          "max": 1800
        }
      }
    },
    {
      "id": 107,
      "title": "Stuck Workspaces",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 38 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "kcp_workspace_stuck_count > 0",
          "legendFormat": "{{phase}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "None",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 108,
      "title": "Shard Health",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 46 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 109,
      "title": "Shard Status",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 47 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "kcp_shard_condition{type=\"Ready\", status=\"True\"} or kcp_shard_info{ready=\"true\"}",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": { "text": "Healthy", "color": "green" }
              }
            },
            {
              "type": "special",
              "options": {
                "match": "null",
                "result": { "text": "Unhealthy", "color": "red" }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 110,
      "title": "Shard Info",
      "type": "table",
      "gridPos": { "h": 6, "w": 12, "x": 6, "y": 47 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "kcp_shard_info",
          "legendFormat": "",
          "format": "table",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "transformations": [
        {
          "id": "labelsToFields",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Value": true,
              "__name__": true,
              "instance": true,
              "job": true
            },
            "renameByName": {
              "name": "Shard",
              "url": "Base URL",
              "ready": "Ready"
            }
          }
        }
      ]
    },
    {
      "id": 111,
      "title": "Total Shards",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 47 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "kcp_shards_total",
          "legendFormat": "Shards"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      }
    }
  ],
