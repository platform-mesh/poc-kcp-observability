apiVersion: v1
kind: Config
clusters:
  - name: kcp
    cluster:
      certificate-authority-data: 
      server: https://kcp.localhost:8443
contexts:
  - name: kcp
    context:
      cluster: kcp
      user: kcp-admin
current-context: kcp
users:
  - name: kcp-admin
    user:
      client-certificate-data: 
      client-key-data: 
